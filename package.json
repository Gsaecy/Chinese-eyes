{
  "name": "ext-trans-picker",
  "displayName": "扩展选择助手",
  "description": "Browse VS Code marketplace, auto-translate details to Chinese, AI summary for usage/pricing/guide",
  "version": "0.3.5",
  "publisher": "honor-world",
  "license": "MIT",
  "activationEvents": [
    "onCommand:chineseEyes.openPanel",
    "onCommand:chineseEyes.openSettings",
    "onCommand:chineseEyes.openTranslator"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "翻译",
    "translate",
    "chinese",
    "中文",
    "marketplace",
    "extension"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gsaecy/Chinese-eyes.git"
  },
  "icon": "media/icon.png",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "扩展选择助手",
      "properties": {
        "chineseEyes.translationProvider": {
          "type": "string",
          "default": "local",
          "description": "翻译提供商",
          "enum": [
            "local",
            "deepl",
            "google",
            "libretranslate",
            "deepseek",
            "openai-compatible"
          ],
          "enumDescriptions": [
            "本地词典（离线、无需 API Key）",
            "DeepL（需 API Key）",
            "Google 翻译（需 API Key）",
            "LibreTranslate（自托管，可选 API Key）",
            "DeepSeek（需 API Key，支持 AI 总结）",
            "OpenAI 兼容协议（需自定义 endpoint/model，支持 AI 总结）"
          ],
          "order": 1
        },
        "chineseEyes.apiKey": {
          "type": "string",
          "default": "",
          "description": "翻译 API 密钥 (DeepSeek/DeepL/Google/OpenAI 兼容)",
          "markdownDescription": "翻译 API 密钥",
          "order": 2
        },
        "chineseEyes.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "自定义 API 端点",
          "markdownDescription": "自定义 API 端点 URL，例如 `https://api.deepseek.com` 或 `https://api.openai.com`",
          "order": 3
        },
        "chineseEyes.apiModel": {
          "type": "string",
          "default": "",
          "description": "自定义模型名称",
          "markdownDescription": "如 `deepseek-chat`、`gpt-4o-mini`、`qwen-plus` 等",
          "order": 4
        },
        "chineseEyes.autoTranslateReadme": {
          "type": "boolean",
          "default": true,
          "description": "打开扩展详情时自动翻译 README 内容",
          "order": 5
        },
        "chineseEyes.pageSize": {
          "type": "number",
          "default": 20,
          "minimum": 10,
          "maximum": 50,
          "description": "扩展列表每页显示数量",
          "order": 6
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chineseEyes-sidebar",
          "title": "扩展选择助手",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "chineseEyes-sidebar": [
        {
          "id": "chineseEyes.marketplace",
          "name": "扩展列表",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "chineseEyes.openPanel",
        "title": "🌐 扩展选择助手 - 打开扩展列表"
      },
      {
        "command": "chineseEyes.openSettings",
        "title": "🌐 扩展选择助手 - 打开设置"
      },
      {
        "command": "chineseEyes.openTranslator",
        "title": "🌐 扩展选择助手 - 打开翻译面板",
        "icon": "$(symbol-text)"
      }
    ],
    "menus": {
      "titleBar": [
        {
          "command": "chineseEyes.openPanel",
          "group": "navigation"
        },
        {
          "command": "chineseEyes.openTranslator",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "clean": "rimraf out"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.15.0",
    "eslint": "^8.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "undici": "^8.3.0"
  }
}